{
  "functions": {
    "api/stripe-webhook.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/sign-license.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/claim-key.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/app/(.*)", "destination": "/app/$1" },
    { "source": "/app", "destination": "/app/" },
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "headers": [
    {
      "source": "/app/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/icons/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
